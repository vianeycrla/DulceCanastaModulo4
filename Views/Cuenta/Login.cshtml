@model DulceCanastaModulo4.Models.LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
}

<section class="auth-page">
    <div class="auth-side">
        <span class="auth-pill">Dulce Canasta</span>
        <h1>Entra y sigue armando tu canasta perfecta.</h1>
        <p>
            Guarda tus datos, revisa tu perfil y haz tus pedidos de fruta fresca de forma más rápida.
        </p>

        <div class="auth-side-image">
            <img src="/images/login-frutas.jpg" alt="Frutas frescas" />
        </div>
    </div>

    <div class="auth-card">
        <h2>Iniciar sesión</h2>
        <p class="auth-subtext">Accede con tu cuenta para continuar.</p>

        @if (ViewBag.Error != null)
        {
            <div class="auth-error">@ViewBag.Error</div>
        }

        <form asp-action="Login" method="post" class="auth-form">
            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="auth-input" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="auth-input" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="auth-btn">Entrar</button>
        </form>

        <div class="auth-footer">
            <span>¿Aún no tienes cuenta?</span>
            <a asp-controller="Cuenta" asp-action="Registro">Crear cuenta</a>
        </div>
    </div>
</section>